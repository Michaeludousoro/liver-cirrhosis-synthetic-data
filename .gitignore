# Virtual environment — never commit
venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter checkpoint folders
.ipynb_checkpoints/

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Pickle files — platform-specific, not portable
*.pkl
*.h5

# Editor settings
.vscode/
.idea/
*.swp
*.swo

# Large intermediate data files that are regenerated by the notebooks
output/data/
